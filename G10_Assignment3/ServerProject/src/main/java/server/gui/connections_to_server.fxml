<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Line?>

<AnchorPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="server.gui.ServerViewController"
            prefHeight="600.0" prefWidth="960.0"
            styleClass="main-background" stylesheets="@serverStyle.css">

    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
            
                <!-- Header Section -->
                <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-padding: 0 0 10 0;">
                    <children>
                        <Label text="SERVER COMMAND CENTER" styleClass="header-label" minWidth="-Infinity" />
                        <Region HBox.hgrow="ALWAYS" />
                        
                        <!-- Status Indicators -->
                        <HBox alignment="CENTER" spacing="15.0" styleClass="glass-pane" style="-fx-padding: 8 20; -fx-background-radius: 20;">
                            <children>
                                <HBox alignment="CENTER" spacing="8.0">
                                    <Label text="DB Connection" style="-fx-text-fill: #bdc3c7; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                                    <Circle radius="6.0" styleClass="status-indicator-green" />
                                </HBox>
                                <Line endY="20.0" startY="5.0" style="-fx-stroke: #555;" />
                                <HBox alignment="CENTER" spacing="8.0">
                                    <Label text="Server Active" style="-fx-text-fill: #bdc3c7; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                                    <Circle radius="6.0" styleClass="status-indicator-green" />
                                </HBox>
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <!-- Main Content (Clients Table) -->
                <VBox spacing="10.0" styleClass="glass-pane" VBox.vgrow="ALWAYS">
                    <Label text="Connected Clients" style="-fx-font-size: 16px; -fx-text-fill: #D4AF37; -fx-font-weight: bold;"/>
                    <TableView fx:id="tblClients" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colIp" text="Client IP" prefWidth="250.0"/>
                            <TableColumn fx:id="colHost" text="Host Name" prefWidth="350.0"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                        <placeholder>
                             <Label text="No clients connected" style="-fx-text-fill: #7f8c8d;" />
                        </placeholder>
                    </TableView>
                </VBox>

                <!-- Terminal Log Area -->
                <VBox spacing="5.0" VBox.vgrow="ALWAYS">
                    <Label text="System Terminal" style="-fx-font-family: 'Consolas'; -fx-text-fill: #2ecc71; -fx-font-weight: bold;"/>
                    <TextArea fx:id="txtLog" editable="false" prefRowCount="8" wrapText="true" 
                              styleClass="terminal-log"
                              VBox.vgrow="ALWAYS" />
                </VBox>

            </children>
        </VBox>
    </children>
</AnchorPane>