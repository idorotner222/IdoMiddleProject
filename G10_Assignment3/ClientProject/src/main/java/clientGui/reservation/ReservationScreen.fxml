<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="720.0" prefWidth="480.0"
	spacing="15.0" styleClass="main-container"
	stylesheets="@../navigation/SelectionScreen.css"
	xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="clientGui.reservation.ReservationController">
	<padding>
		<Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
	</padding>

	<children>
		<Label styleClass="title-label" text="MAKE A RESERVATION">
			<font>
				<Font name="System Bold" size="24.0" />
			</font>
			<VBox.margin>
				<Insets bottom="10.0" />
			</VBox.margin>
		</Label>

		<GridPane hgap="15.0" vgap="15.0">
			<columnConstraints>
				<ColumnConstraints hgrow="NEVER" minWidth="60.0"
					prefWidth="70.0" />
				<ColumnConstraints hgrow="SOMETIMES"
					minWidth="10.0" prefWidth="120.0" />
				<ColumnConstraints hgrow="NEVER" minWidth="60.0"
					prefWidth="60.0" />
				<ColumnConstraints hgrow="SOMETIMES"
					minWidth="10.0" prefWidth="120.0" />
			</columnConstraints>

			<rowConstraints>
				<RowConstraints minHeight="45.0" prefHeight="45.0"
					vgrow="SOMETIMES" />
				<RowConstraints minHeight="45.0" prefHeight="45.0"
					vgrow="SOMETIMES" />
				<RowConstraints minHeight="45.0" prefHeight="45.0"
					vgrow="SOMETIMES" />
			</rowConstraints>

			<children>
				<Label fx:id="lblSubCode" styleClass="subtitle-label"
					text="Sub ID:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
				<TextField fx:id="subscriberIdField" promptText="ID"
					styleClass="input-field" GridPane.columnIndex="1"
					GridPane.rowIndex="0" />

				<Label styleClass="subtitle-label" text="Diners:"
					GridPane.columnIndex="2" GridPane.rowIndex="0" />
				<TextField fx:id="guestsField" promptText="Amount"
					styleClass="input-field" GridPane.columnIndex="3"
					GridPane.rowIndex="0" />

				<Label styleClass="subtitle-label" text="Name:"
					GridPane.columnIndex="0" GridPane.rowIndex="1" />
				<TextField fx:id="nameField" promptText="Name"
					styleClass="input-field" GridPane.columnIndex="1"
					GridPane.rowIndex="1" />

				<Label styleClass="subtitle-label" text="Phone:"
					GridPane.columnIndex="2" GridPane.rowIndex="1" />
				<TextField fx:id="phoneField" promptText="Phone"
					styleClass="input-field" GridPane.columnIndex="3"
					GridPane.rowIndex="1" />

				<Label styleClass="subtitle-label" text="Email:"
					GridPane.columnIndex="0" GridPane.rowIndex="2" />
				<TextField fx:id="emailField"
					promptText="example@mail.com" styleClass="input-field"
					GridPane.columnIndex="1" GridPane.columnSpan="3"
					GridPane.rowIndex="2" />
			</children>

			<VBox.margin>
				<Insets bottom="10.0" />
			</VBox.margin>
		</GridPane>

		<VBox spacing="5.0">
			<children>
				<Label styleClass="subtitle-label" text="Select Date:" />
				<DatePicker fx:id="datePicker"
					maxWidth="1.7976931348623157E308"
					promptText="Pick a date to see hours" styleClass="input-field" />
			</children>
		</VBox>

		<VBox spacing="10.0" VBox.vgrow="ALWAYS">
			<children>
				<HBox alignment="CENTER_LEFT" spacing="15.0">
					<children>
						<Label styleClass="subtitle-label" text="Select Time:" />

						<HBox alignment="CENTER_RIGHT" spacing="10.0"
							HBox.hgrow="ALWAYS">
							<children>
								<HBox alignment="CENTER" spacing="4.0">
									<Circle fill="WHITE" radius="4.0" stroke="#4caf50" />
									<Label style="-fx-font-size: 10px;" text="Free"
										textFill="#777" />
								</HBox>
								<HBox alignment="CENTER" spacing="4.0">
									<Circle fill="#3498db" radius="4.0" stroke="#2980b9" />
									<Label style="-fx-font-size: 10px;" text="Waiting List"
										textFill="#777" />
								</HBox>
							</children>
						</HBox>
					</children>
				</HBox>

				<ScrollPane fitToWidth="true" hbarPolicy="NEVER"
					minHeight="120.0"
					style="-fx-background-color: transparent; -fx-background: transparent;">
					<content>
						<TilePane fx:id="timeContainer" hgap="10.0"
							prefColumns="3" tileAlignment="CENTER" vgap="10.0">
							<padding>
								<Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
							</padding>
						</TilePane>
					</content>
				</ScrollPane>
			</children>
		</VBox>

		<Label fx:id="errorLabel" textFill="#e74c3c" wrapText="true" />

		<VBox spacing="10.0">
			<children>
				<Button mnemonicParsing="false" onAction="#submitReservation"
					prefHeight="45.0" prefWidth="400.0"
					styleClass="menu-button, primary-button" text="Book Table" />
				<Button mnemonicParsing="false" onAction="#goBack"
					prefHeight="45.0" prefWidth="400.0" styleClass="menu-button"
					text="Back" />
			</children>
		</VBox>
	</children>
</VBox>