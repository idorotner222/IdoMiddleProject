<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="rootPane" prefHeight="600.0"
	prefWidth="1100.0" styleClass="main-background"
	stylesheets="@../reservation/orderUi.css"
	xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="clientGui.reservation.OrderUi_controller">

	<children>
		<VBox spacing="20.0" AnchorPane.bottomAnchor="0.0"
			AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
			AnchorPane.topAnchor="0.0" alignment="CENTER">
			<padding>
				<Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
			</padding>
			<children>
				<VBox spacing="20.0" styleClass="glass-pane"
					VBox.vgrow="ALWAYS">
					<BorderPane>
						<left>
							<Button graphicTextGap="10.0" mnemonicParsing="false"
								onAction="#handleBackBtn" styleClass="back-button" text="← BACK"
								BorderPane.alignment="CENTER" />
						</left>
						<center>
							<Label styleClass="header-label" text="Order Management"
								BorderPane.alignment="CENTER">
							</Label>
						</center>
						<right>
							<!-- Spacer to balance the title centering -->
							<HBox prefWidth="80.0" BorderPane.alignment="CENTER" />
						</right>
					</BorderPane>

					<HBox alignment="CENTER_LEFT" spacing="20.0"
						style="-fx-padding: 10 0 10 0;">
						<children>
							<HBox alignment="CENTER_LEFT" spacing="10.0">
								<Label text="Filter by Date:"
									style="-fx-font-weight: bold; -fx-text-fill: #bdc3c7;" />
								<DatePicker fx:id="filterDatePicker"
									promptText="Select date" prefWidth="180.0"
									styleClass="date-picker" />
							</HBox>

							<HBox alignment="CENTER_LEFT" spacing="10.0">
								<Label text="Status:"
									style="-fx-font-weight: bold; -fx-text-fill: #bdc3c7;" />
								<ComboBox fx:id="cmbStatusFilter"
									promptText="All Statuses" prefWidth="180.0"
									styleClass="combo-box" />
							</HBox>

							<Button text="CLEAR FILTER" onAction="#handleClearFilter"
								styleClass="action-button, secondary-button" />
						</children>
					</HBox>

					<TableView fx:id="orderTable" editable="true"
						VBox.vgrow="ALWAYS" styleClass="table-view">
						<columns>
							<TableColumn fx:id="Order_numberColumn" text="#"
								prefWidth="50.0" minWidth="50.0" />

							<TableColumn fx:id="clientNameColumn"
								text="Client Name" prefWidth="140.0" minWidth="140.0" />

							<TableColumn fx:id="clientPhoneColumn" text="Phone"
								prefWidth="110.0" minWidth="110.0" />

							<TableColumn fx:id="clientEmailColumn" text="Email"
								prefWidth="180.0" minWidth="180.0" />

							<TableColumn fx:id="customer_idColumn" text="Cus. ID"
								prefWidth="70.0" minWidth="70.0" />

							<TableColumn fx:id="DateColumn" text="Date"
								prefWidth="110.0" minWidth="110.0" />

							<TableColumn fx:id="arrivalTimeColumn" text="Time"
								prefWidth="90.0" minWidth="90.0" />

							<TableColumn fx:id="itemColumn" text="Guests"
								prefWidth="70.0" minWidth="70.0" style="-fx-alignment: CENTER;" />

							<TableColumn fx:id="totalPriceColumn" text="Price"
								prefWidth="80.0" minWidth="80.0" />

							<TableColumn fx:id="statusColumn" text="Status"
								prefWidth="110.0" minWidth="110.0" />

							<TableColumn fx:id="confirmation_codeColumn"
								text="Code" prefWidth="70.0" minWidth="70.0" />

							<TableColumn fx:id="date_of_placing_orderColumn"
								text="Created On" prefWidth="200.0" minWidth="200.0" />
						</columns>

						<columnResizePolicy>
							<TableView fx:constant="UNCONSTRAINED_RESIZE_POLICY" />
						</columnResizePolicy>

						<placeholder>
							<Label text="No orders to display"
								style="-fx-text-fill: #7f8c8d; -fx-font-size: 16px;" />
						</placeholder>
					</TableView>
					<HBox alignment="CENTER" spacing="30.0"
						style="-fx-padding: 10 0 0 0;">
						<children>
							<Button mnemonicParsing="false" onAction="#handleAddOrder"
								prefHeight="45.0" prefWidth="150.0"
								styleClass="action-button, add-button" text="ADD ORDER" />
							<Button mnemonicParsing="false"
								onAction="#handleUpdateOrder" prefHeight="45.0"
								prefWidth="150.0" styleClass="action-button, update-button"
								text="UPDATE ORDER" />
							<Button mnemonicParsing="false"
								onAction="#handleDeleteOrder" prefHeight="45.0"
								prefWidth="150.0" styleClass="action-button, delete-button"
								text="DELETE SELECTED" />
						</children>
					</HBox>
				</VBox>
			</children>
		</VBox>
	</children>
</AnchorPane>