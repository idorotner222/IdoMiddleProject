<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="500.0" prefWidth="400.0" spacing="15.0" styleClass="main-container" stylesheets="@../navigation/SelectionScreen.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="clientGui.user.SubscriberOptionController">

   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>

   <children>
      
      <HBox alignment="CENTER_LEFT" prefHeight="60.0" prefWidth="290.0" style="-fx-background-color: rgba(255,255,255,0.6); -fx-background-radius: 10; -fx-padding: 10;">
         <children>
            <VBox alignment="CENTER_LEFT">
               <children>
                  <Label text="Welcome back," textFill="#666666">
                     <font>
                        <Font size="11.0" />
                     </font>
                  </Label>
                  <Label fx:id="lblCustomerName" text="Guest" textFill="#333333">
                     <font>
                        <Font name="System Bold" size="15.0" />
                     </font>
                  </Label>
               </children>
            </VBox>
            
            <Region HBox.hgrow="ALWAYS" />
            
            <Button fx:id="btnEditProfile" 
                    visible="false" managed="false" 
                    mnemonicParsing="false" 
                    onAction="#goToUpdateProfile" 
                    style="-fx-background-color: transparent; -fx-cursor: hand;">
               <graphic>
                  <SVGPath content="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" 
                           fill="#555555" scaleX="1.3" scaleY="1.3" />
               </graphic>
               <tooltip>
                  <Tooltip text="View/Edit Profile" />
               </tooltip>
            </Button>
         </children>
         <VBox.margin>
            <Insets bottom="10.0" />
         </VBox.margin>
      </HBox>

      <Label styleClass="title-label" text="CHOOSE ACTION">
         <VBox.margin>
            <Insets bottom="5.0" />
         </VBox.margin>
      </Label>

      <Button mnemonicParsing="false" onAction="#goToReservationBtn" prefHeight="45.0" prefWidth="280.0" styleClass="menu-button, primary-button" text="Order Place" />
      
      <Button mnemonicParsing="false" onAction="#goToSeatTableBtn" prefHeight="45.0" prefWidth="280.0" styleClass="menu-button, primary-button" text="Receive Table" />
              
      <Button mnemonicParsing="false" onAction="#CheckOutActionBtn" prefHeight="45.0" prefWidth="280.0" styleClass="menu-button, primary-button" text="Check Out" />
              
      <Button fx:id="btnSubscriberSpecial" managed="false" mnemonicParsing="false" onAction="#subscriberActionBtn" prefHeight="45.0" prefWidth="280.0" styleClass="menu-button, primary-button" text="Subscriber History" visible="false" />

      <Region VBox.vgrow="ALWAYS" />

       <Button mnemonicParsing="false" onAction="#goBackBtn" prefHeight="45.0" prefWidth="280.0" styleClass="menu-button" text="Back" />
   </children>
</VBox>