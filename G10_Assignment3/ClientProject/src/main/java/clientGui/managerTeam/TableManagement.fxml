<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<VBox alignment="TOP_CENTER" spacing="20.0" styleClass="main-background" stylesheets="@../navigation/SelectionScreen.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="clientGui.managerTeam.TableManagementController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="30.0" />
    </padding>

    <VBox spacing="15.0" styleClass="glass-pane" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <VBox alignment="CENTER_LEFT">
                <Label styleClass="title-label" text="Table Management" />
                <Label styleClass="subtitle-label" text="Add, update, or remove restaurant tables" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#handleBackBtn" styleClass="menu-button" text="Back" />
        </HBox>
    
        <TableView fx:id="tablesUserId" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colTableNumber" text="Table Number" />
                <TableColumn fx:id="colSeats" text="Seats" />
                <TableColumn fx:id="colStatus" text="Status" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    
        <HBox alignment="CENTER" spacing="15.0">
            <TextField fx:id="txtTableNumber" promptText="Table Number" styleClass="input-field" />
            <TextField fx:id="txtSeats" promptText="Seats" styleClass="input-field" />
            <Button onAction="#handleClearBtn" styleClass="menu-button" text="CLEAR / NEW" />
            <Button onAction="#handleAddTable" styleClass="menu-button" text="ADD TABLE" />
            <Button onAction="#handleUpdateTable" styleClass="menu-button" text="UPDATE SEATS" />
        </HBox>
        
        <HBox alignment="CENTER">
             <Button onAction="#handleDeleteTable" styleClass="menu-button" style="-fx-border-color: #e74c3c; -fx-text-fill: #e74c3c;" text="DELETE SELECTED TABLE" />
        </HBox>
    </VBox>

</VBox>
