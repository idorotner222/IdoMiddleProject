<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="20.0" styleClass="main-background" stylesheets="@../navigation/SelectionScreen.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="clientGui.managerTeam.SubscriberManagementController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="30.0" />
    </padding>

    <VBox spacing="15.0" styleClass="glass-pane" VBox.vgrow="ALWAYS">
        
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <VBox alignment="CENTER_LEFT">
                <Label styleClass="title-label" text="Subscriber Management" />
                <Label styleClass="subtitle-label" text="View all registered subscribers" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#goBackBtn" styleClass="menu-button" text="Back" />
        </HBox>
    
        <TableView fx:id="subscriberTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="Sub Code" />
                <TableColumn fx:id="colName" text="Name" />
                <TableColumn fx:id="colPhone" text="Phone" />
                <TableColumn fx:id="colEmail" text="Email" />
                <TableColumn fx:id="colType" text="Type" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    
        <HBox alignment="CENTER" spacing="15.0">
            <Label styleClass="subtitle-label" text="* Double-click on a row to view order history" style="-fx-text-fill: #d4af37;" />
        </HBox>
        
    </VBox>

</VBox>