<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="700.0" styleClass="main-background" stylesheets="@EmployeeOption.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="clientGui.managerTeam.MonthlyReportsController">
   <children>
      <VBox alignment="TOP_CENTER" spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
         </padding>
         <children>
            <Label styleClass="header-label" text="MONTHLY REPORTS ARCHIVE" />
            <Label styleClass="subtitle-label" text="Select a month and year to download the operations report" />
            
            <Separator prefWidth="200.0" visible="false" />
            
            <VBox alignment="CENTER" maxWidth="500.0" spacing="15.0" styleClass="glass-pane">
               <children>
                  <HBox alignment="CENTER" spacing="25.0">
                     <children>
                        <VBox spacing="8.0">
                           <children>
                              <Label style="-fx-font-weight: bold; -fx-text-fill: #E1E1E1;" text="Select Month:" />
                              <ComboBox fx:id="cmbMonth" prefWidth="180.0" promptText="Month" styleClass="combo-box-dark" />
                           </children>
                        </VBox>
                        <VBox spacing="8.0">
                           <children>
                              <Label style="-fx-font-weight: bold; -fx-text-fill: #E1E1E1;" text="Select Year:" />
                              <ComboBox fx:id="cmbYear" prefWidth="150.0" promptText="Year" styleClass="combo-box-dark" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  
                  <Button fx:id="btnDownload" maxWidth="250.0" mnemonicParsing="false" onAction="#downloadReportBtn" prefHeight="45.0" styleClass="menu-button, primary-button" text="DOWNLOAD REPORT" />
                  
                  <Label fx:id="lblStatus" alignment="CENTER" text="" style="-fx-text-fill: #e74c3c; -fx-font-weight: bold;" wrapText="true" />
               </children>
            </VBox>
            
            <Button mnemonicParsing="false" onAction="#backBtn" styleClass="menu-button" text="BACK TO DASHBOARD" />
         </children>
      </VBox>
   </children>
</AnchorPane>