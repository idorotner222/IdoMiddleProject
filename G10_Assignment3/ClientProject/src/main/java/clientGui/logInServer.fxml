<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="clientGui.LoginController"
            prefWidth="500.0" prefHeight="350.0"
            styleClass="main-background" stylesheets="@reservation/orderUi.css">

    <children>
        <VBox alignment="CENTER" spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label text="SERVER CONNECTION" styleClass="header-label" style="-fx-font-size: 32px;"/>
                
                <VBox alignment="CENTER" spacing="10.0" styleClass="glass-pane" maxWidth="350.0">
                     <children>
                        <Label text="Server IP Address:" style="-fx-text-fill: #E1E1E1; -fx-font-size: 14px;"/>
                        <TextField fx:id="txtIp"
                                   promptText="e.g. 127.0.0.1"
                                   styleClass="input-field"
                                   prefWidth="250.0"/>
                        <Button text="CONNECT"
                                onAction="#onConnect"
                                styleClass="action-button"
                                prefWidth="150.0"/>
                     </children>
                </VBox>

                <Label fx:id="lblStatus" style="-fx-text-fill: #e74c3c; -fx-font-weight: bold;"/>
            </children>
        </VBox>
    </children>
</AnchorPane>
